# Database (Railway provides this automatically when you add a PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Admin authentication token (choose a strong random string)
ADMIN_TOKEN=change-me-to-a-secure-random-string

# Web Push (VAPID keys) - Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Raid scraper (auto-updates boss rotations from community sources)
RAID_SCRAPER_ENABLED=true

# Server config
NODE_ENV=production
PORT=5000
